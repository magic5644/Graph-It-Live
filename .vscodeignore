# VS Code / IDE
.vscode/**
.vscode-test/**

# Local tool/editor dirs (must never be packaged)
.venv/**
.env/**
.graph-it/**
.obsidian/**
.code-review-graph/**
.qoder/**
.tokensave/**
__pycache__/**
*.pyc
.nvmrc
.antigravitycli/**
.prompts/**
.copilotignore
.graphifyignore

# Build info & generated metadata files
tsconfig.tsbuildinfo
*.tsbuildinfo
meta.json
metadata.json
DEVELOPMENT.md
CLAUDE.md
.claude/**

# Source code (bundled in dist/)
src/**
tests/**

# Source maps (NEVER include in production)
**/*.map

# Query files are copied to dist/queries/ at build time
resources/queries/**

# WASM files (MUST be included for tree-sitter parsers)
!dist/wasm/**

# Dependencies - exclude all, then include only required runtime files
node_modules/**

# web-tree-sitter is externalized by esbuild for extension/workers.
# Parser initialization explicitly loads dist/wasm/tree-sitter.wasm, so only
# JavaScript module-resolution files are needed here.
!node_modules/web-tree-sitter/package.json
!node_modules/web-tree-sitter/web-tree-sitter.cjs
!node_modules/web-tree-sitter/web-tree-sitter.js

# Build artifacts & intermediates
out/**
out-webview/**
coverage/**
verbose/**
test-results/**
*.vsix
dist/*.meta.json

# CLI standalone binary — not part of the VS Code extension package
# All variants (CJS .js and ESM .mjs) are excluded; the extension uses
# dist/mcpServer.mjs internally — the CLI is a separate npm package.
dist/graph-it.js
dist/graph-it.js.map
dist/graph-it.mjs
dist/graph-it.mjs.map
bin/**

# Config files
.gitignore
.eslintignore
.eslintrc.json
eslint.config.mjs
esbuild.js
tsconfig.json
tsconfig.webview.json
tsconfig.test.json
tsconfig.test.node.json
tsconfig.test.webview.json
tsconfig.vscode-e2e.json
tsconfig.test.tsbuildinfo
vitest.config.ts
vitest.config.mjs
vitest.config.mts
vitest.benchmark.config.mts
vitest.memory.config.mts
sonar-project.properties
package-lock.json
.markdownlint.json
.markdownlintignore
skills-lock.json
tsconfig.eslint.json


# Development & documentation files
.github/**
.gemini/**
.spec/**
.clavix/**
.reports/**
.specify/**
codemaps/**
specs/**
docs/**
!docs/CLI.md
scripts/**
_bmad/**
_bmad-output/**
PROMPT_SPEC.md
walkthrough.md
implementation_plan.md
AGENTS.md
*.log
task.md
test.log

# AI/Agent configuration directories (may contain large files or binaries)
.agent/**
.agents/**
.claude/**
.codex/**
.continue/**
.cursor/**
.goose/**
.roo/**
.kiro/**
plan/**

# Knowledge graph & analysis output (dev-only, never ship)
graphify-out/**
.serena/**
wiki/**

# OS files
.DS_Store
**/.DS_Store
